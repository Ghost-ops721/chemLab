rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      function allowedKeys() {
        return [
          'email',
          'displayName',
          'phone',
          'gender',
          'dob',
          'age',
          'address',
          'pincode',
          'xp',
          'discoveredIds',
          'badgeIds',
          'stars',
          'lastDailyStarAt',
          'unlockedShopItemIds',
          'completedPerfumeIds',
          'createdAt',
          'updatedAt',
          'lastSeenAt'
        ];
      }

      function hasOnlyAllowedKeys() {
        return request.resource.data.keys().hasOnly(allowedKeys());
      }

      function progressEmpty() {
        return request.resource.data.xp == 0
          && request.resource.data.discoveredIds.size() == 0
          && request.resource.data.badgeIds.size() == 0
          && request.resource.data.get('stars', 0) == 0
          && request.resource.data.get('unlockedShopItemIds', []).size() == 0
          && request.resource.data.get('completedPerfumeIds', []).size() == 0;
      }

      function progressUnchanged() {
        return request.resource.data.xp == resource.data.xp
          && request.resource.data.discoveredIds == resource.data.discoveredIds
          && request.resource.data.badgeIds == resource.data.badgeIds
          && request.resource.data.get('stars', 0) == resource.data.get('stars', 0)
          && request.resource.data.get('lastDailyStarAt', 0) == resource.data.get('lastDailyStarAt', 0)
          && request.resource.data.get('unlockedShopItemIds', []) == resource.data.get('unlockedShopItemIds', [])
          && request.resource.data.get('completedPerfumeIds', []) == resource.data.get('completedPerfumeIds', []);
      }

      allow read: if isOwner();

      allow create: if isOwner()
        && hasOnlyAllowedKeys()
        && progressEmpty()
        && request.resource.data.email is string
        && request.resource.data.createdAt is number
        && request.resource.data.updatedAt is number;

      allow update: if isOwner()
        && hasOnlyAllowedKeys()
        && progressUnchanged()
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    // Admin + analytics: server Admin SDK only (no client access)
    match /admins/{uid} {
      allow read, write: if false;
    }
    match /analytics_events/{id} {
      allow read, write: if false;
    }
    match /llm_usage/{id} {
      allow read, write: if false;
    }
    match /metrics_daily/{day} {
      allow read, write: if false;
    }
    match /waitlist/{id} {
      allow read, write: if false;
    }
    match /admin_audit/{id} {
      allow read, write: if false;
    }
    match /orgs/{orgId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /orgMembers/{id} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid
          || exists(/databases/$(database)/documents/orgMembers/$(resource.data.orgId + '_' + request.auth.uid)));
      allow write: if false;
    }
    match /classes/{classId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /classMembers/{id} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid
          || get(/databases/$(database)/documents/classes/$(resource.data.classId)).data.teacherUid == request.auth.uid);
      allow write: if false;
    }
    match /orgUsageDaily/{id} {
      allow read, write: if false;
    }

    // Marketplace formulas — public read, owner write
    match /formulas/{formulaId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.contents is list
        && request.resource.data.keys().hasAll([
          'title', 'authorUid', 'authorName', 'contents', 'equipmentId',
          'ifra', 'badge', 'createdAt', 'updatedAt'
        ]);
      allow update: if request.auth != null
        && resource.data.authorUid == request.auth.uid
        && request.resource.data.authorUid == resource.data.authorUid;
      allow delete: if request.auth != null
        && resource.data.authorUid == request.auth.uid;
    }

    // Panelist studies — public read; creator create/update
    match /studies/{studyId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.creatorUid == request.auth.uid
        && request.resource.data.formulaId is string
        && request.resource.data.mode in ['blind', 'labeled'];
      allow update: if request.auth != null
        && resource.data.creatorUid == request.auth.uid
        && request.resource.data.creatorUid == resource.data.creatorUid;
      // Allow any authenticated panelist to refresh aggregate after rating
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['aggregate', 'updatedAt']);
      allow delete: if request.auth != null
        && resource.data.creatorUid == request.auth.uid;
    }

    // One rating per (study, uid) — doc id `${studyId}_${uid}`
    match /study_ratings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.raterUid == request.auth.uid
        && ratingId == request.resource.data.studyId + '_' + request.auth.uid
        && request.resource.data.liking is number
        && request.resource.data.harshness is number
        && request.resource.data.longevityGuess is number
        && request.resource.data.clarity is number
        && request.resource.data.uniqueness is number
        && request.resource.data.liking >= 1 && request.resource.data.liking <= 7
        && request.resource.data.harshness >= 1 && request.resource.data.harshness <= 7
        && request.resource.data.longevityGuess >= 1 && request.resource.data.longevityGuess <= 7
        && request.resource.data.clarity >= 1 && request.resource.data.clarity <= 7
        && request.resource.data.uniqueness >= 1 && request.resource.data.uniqueness <= 7;
      allow update, delete: if false;
    }
  }
}
